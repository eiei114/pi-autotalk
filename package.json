{
  "name": "pi-autotalk",
  "version": "0.1.1",
  "description": "A Pi extension for timed AutoTalk brainstorming from the editor input.",
  "type": "module",
  "license": "MIT",
  "author": "eiei114",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "autotalk",
    "brainstorming",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiei114/pi-autotalk.git"
  },
  "bugs": {
    "url": "https://github.com/eiei114/pi-autotalk/issues"
  },
  "homepage": "https://github.com/eiei114/pi-autotalk#readme",
  "files": [
    "extensions/",
    "lib/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "ci": "npm run typecheck && npm test && npm run pack:check",
    "pack:check": "npm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
